# ──────────────────────────────────────────────────────────────
# Server
# ──────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Comma-separated origins for CORS (leave blank = allow all; lock down in prod)
CORS_ORIGIN=

# ──────────────────────────────────────────────────────────────
# Twilio — https://console.twilio.com
# ──────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15551234567

# ──────────────────────────────────────────────────────────────
# Calendly — https://calendly.com/integrations/api_webhooks
# ──────────────────────────────────────────────────────────────
CALENDLY_API_TOKEN=eyJhbGciOiJIUzI1NiJ9.your_token_here

# Static Calendly scheduling URLs (used by send_calendly_link tool)
CALENDLY_URL_NEW_PATIENT=https://calendly.com/yourname/new-patient
CALENDLY_URL_EXISTING_PATIENT=https://calendly.com/yourname/existing-patient
CALENDLY_URL_SALES=https://calendly.com/yourname/sales-call
CALENDLY_URL_SUPPORT=https://calendly.com/yourname/support

# ──────────────────────────────────────────────────────────────
# Vapi — https://dashboard.vapi.ai
# Generate: openssl rand -hex 32
# ──────────────────────────────────────────────────────────────
VAPI_WEBHOOK_SECRET=replace_with_a_long_random_secret

# ──────────────────────────────────────────────────────────────
# OpenAI — https://platform.openai.com/api-keys
# Supported LLM_PROVIDER values: openai (more providers coming)
# ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini
LLM_PROVIDER=openai

# ──────────────────────────────────────────────────────────────
# Supabase — https://supabase.com/dashboard → Project Settings → API
# WARNING: SUPABASE_SERVICE_ROLE_KEY is a server-only secret.
# Never expose it to a browser, mobile app, or client-side code.
# ──────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your_service_role_key
